{
  "name": "shortcutsflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ShortcutsFlow is a TypeScript framework for generating Apple Shortcuts workflow files.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run shortcut:check && tsc -b tsconfig.build.json",
    "clean": "rm -rf packages/*/dist examples/dist",
    "example:build": "tsx packages/cli/src/main.ts build examples/basic-shortcut.ts --out-dir examples/dist",
    "example:inspect": "tsx packages/cli/src/main.ts inspect examples/dist/basic-shortcut.unsigned.shortcut",
    "shortcut:check": "tsx packages/cli/src/main.ts check",
    "test": "npm run build && tsx --test tests/action/*.test.ts",
    "typecheck": "tsc -b tsconfig.build.json --pretty false"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

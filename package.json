{
  "name": "shortcutsflow-monorepo",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "ShortcutsFlow is a TypeScript framework for generating Apple Shortcuts workflow files.",
  "workspaces": [
    "packages/shortcutsflow",
    "packages/create"
  ],
  "scripts": {
    "build": "npm run shortcut:check && tsc -b tsconfig.build.json",
    "clean": "rm -rf packages/*/dist examples/dist",
    "example:build": "tsx packages/shortcutsflow/src/cli/main.ts build",
    "example:inspect": "tsx packages/shortcutsflow/src/cli/main.ts inspect examples/dist/basic-shortcut.unsigned.shortcut",
    "version": "node scripts/sync-workspace-versions.js",
    "shortcut:check": "tsx packages/shortcutsflow/src/cli/main.ts check",
    "test": "npm run build && tsx --test tests/action/*.test.ts tests/*.test.ts",
    "typecheck": "tsc -b tsconfig.build.json --pretty false"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

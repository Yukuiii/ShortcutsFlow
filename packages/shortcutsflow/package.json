{
  "name": "shortcutsflow",
  "version": "0.1.2",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "shortcutsflow": "dist/cli/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./actions": {
      "types": "./dist/actions/index.d.ts",
      "default": "./dist/actions/index.js"
    },
    "./compiler": {
      "types": "./dist/compiler/index.d.ts",
      "default": "./dist/compiler/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./plist": {
      "types": "./dist/plist/index.d.ts",
      "default": "./dist/plist/index.js"
    }
  },
  "files": [
    "dist",
    "NATIVE_ACTIONS.md"
  ],
  "dependencies": {
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
